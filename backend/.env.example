# EMS Environment Variables Example
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file.

# === Security (CRITICAL) ===
SECRET_KEY=your-super-long-random-secret-key-at-least-50-characters-here
ENVIRONMENT=development

# === Database ===
DATABASE_URL=postgresql://user:password@localhost:5432/ems

# === CORS / Hosts ===
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1

# === Logging & Debug ===
DEBUG=true
LOG_LEVEL=INFO

# === Feature Flags ===
MULTI_FACULTY_ENABLED=false
RETENTION_CLEANUP_ENABLED=false

# === PDPA / Retention ===
PDPA_RETENTION_DAYS=365
